        <item name="android:windowBackground">@color/prime_background</item>
        <item name="colorPrimary">@color/prime_accent</item>
        <item name="colorPrimaryDark">@color/prime_background</item>
        <item name="colorAccent">@color/prime_accent</item>
        <item name="android:colorPrimary">@color/prime_accent</item>
