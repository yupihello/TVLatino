<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="400dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:orientation="vertical"
    android:background="@drawable/card_default_border"
    android:clipToOutline="true"
    android:focusable="true">

    <!-- Thumbnail with progress bar overlay -->
    <FrameLayout
        android:layout_width="400dp"
        android:layout_height="225dp">

        <ImageView
            android:id="@+id/continue_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <!-- Progress bar at bottom of thumbnail -->
        <ProgressBar
            android:id="@+id/continue_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_gravity="bottom"
            android:max="100"
            android:progressTint="@color/prime_accent"
            android:progressBackgroundTint="#44FFFFFF" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@color/prime_card">

        <TextView
            android:id="@+id/continue_series_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/prime_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/continue_episode_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/prime_text_sec"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
